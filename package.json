{
    "name": "@stateforward/hsm",
    "version": "1.1.1",
    "description": "High-performance Hierarchical State Machine implementation optimized for JavaScript and Espruino",
    "main": "src/hsm.js",
    "types": "src/hsm.d.ts",
    "scripts": {
        "build": "npm run generate-types && npm run minify",
        "test": "node --test tests/*.test.js",
        "coverage": "node --test --experimental-test-coverage --test-coverage-lines=90 tests/*.test.js",
        "generate-types": "tsc",
        "terser": "terser --config-file terser.config.json -o dist/hsm.min.js -- src/hsm.js",
        "minify": "uglifyjs src/hsm.js -o dist/hsm.min.js --config-file .uglifyjsrc.json --name-cache nameCache.json"
    },
    "keywords": [
        "state-machine",
        "hsm",
        "finite-state-machine",
        "hierarchical",
        "promise",
        "async",
        "espruino",
        "embedded",
        "performance",
        "optimized",
        "join"
    ],
    "author": "HSM Team",
    "license": "MIT",
    "engines": {
        "node": ">=12.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/stateforward/hsm.js.git"
    },
    "bugs": {
        "url": "https://github.com/stateforward/hsm.js/issues"
    },
    "homepage": "https://github.com/stateforward/hsm.js#readme",
    "devDependencies": {
        "terser": "^5.41.0",
        "typescript": "^5.8.3",
        "uglify-js": "^3.19.3"
    },
    "exports": {
        ".": {
            "types": "./src/hsm.d.ts",
            "require": "./src/hsm.js",
            "import": "./src/hsm.js"
        }
    },
    "files": [
        "README.md",
        "src"
    ],
    "publishConfig": {
        "access": "public"
    }
}
